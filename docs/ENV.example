# Remote Center ERP — environment variables (optional)

# production | development (production hides error details from API responses)
APP_ENV=development
#
# Prefer config/local.php for XAMPP (see config/local.php.example).
# Or set these in Apache/PHP environment before starting the app.

# Firebase Cloud Messaging (warehouse push on new invoice)
FCM_SERVER_KEY=your-fcm-server-key-here
FCM_VAPID_KEY=your-fcm-web-push-vapid-key-here

# Database (optional override; defaults are in config/config.php)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=osudlagb_remotecenter